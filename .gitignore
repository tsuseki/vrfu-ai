# ─── vrfu-ai — .gitignore ──────────────────────────────────────────
# Goal: ship code + scaffolding + docs. Don't ship binaries, personal data,
# generated content, machine-specific state, or one-shot helper scripts.

# ─── Big binaries — re-downloadable / re-trainable ──────────────────────
checkpoints/*.safetensors
checkpoints/*.ckpt
loras/**/*.safetensors
loras/**/*.pt
loras/**/optimizer.pt
loras/**/samples/
loras/**/*.jpg
loras/**/*.png
upscalers/*.pth
upscalers/*.safetensors

# ─── User personal data per character ───────────────────────────────────
# Generated images and votes are not shareable.
characters/*/output/
characters/*/archive/
characters/*/liked/
characters/*/liked_upscaled/

# ─── Unified runtime queue + migration leftovers ───────────────────────
# queue.yaml at project root is per-user runtime state (the prompts you've
# queued up for generation). Each user has their own; not shareable.
queue.yaml
characters/*/queue.yaml.legacy_per_char
characters/*/done.yaml
characters/*/upscaled.yaml
characters/*/liked_images.txt
characters/*/feedback.json
characters/*/.queue.bak

# Training images — your friend's data, not yours to ship.
# Demo character + _template have their own example images that ARE tracked
# (see allow rules below).
characters/*/training/

# Per-character caption helpers (write_captions.py) — these are bespoke per
# character, not a reusable framework. Each character's owner writes their own.
characters/*/write_captions.py

# Per-machine + per-user state
characters/*/queue.yaml
characters/*/last_id.txt

# ─── Allow scaffolding back in (negate the above where appropriate) ────
!characters/_template/training/
!characters/_template/training/**
!characters/demo_character/training/
!characters/demo_character/training/**

# ─── ai-toolkit submodule — venv + runtime artifacts not in git ─────────
ai-toolkit/venv/
ai-toolkit/output/
# (the rest is automatically excluded since it's tracked upstream, not by us)

# ─── One-shot scripts (kept on disk, not committed) ─────────────────────
# These were written for specific characters / specific batches and aren't
# part of the reusable framework.
scripts/_gen_*.py
scripts/seed_*.py
scripts/tweak_*.py
scripts/add_*.py
scripts/extend_*.py
scripts/build_overnight_batch.py
scripts/append_queue.py
# Top-level legacy helper, superseded by characters/_template/ example
write_captions.py

# ─── Caches / build artifacts ───────────────────────────────────────────
characters/_cache/
characters/*/training/_latent_cache/
characters/*/logs/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ─── Runtime artifacts ──────────────────────────────────────────────────
web/data/feedback.json
web/data/batches.json
web/server_log.txt
activity.jsonl

# Auto-generated reference docs
docs/REFERENCE_*.md

# ─── Personal helpers + local notes ────────────────────────────────────
# train.bat / watch_*.ps1 / RESUME_TRAINING.txt that aren't part of the
# shareable framework — kept on disk for the user, not in git.
personal/

# ─── Local backups + editor / OS junk ───────────────────────────────────
*.bak
*.bak2
_backups/
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Auto-generated by ai-toolkit during training (a snapshot of training_config)
loras/*/config.yaml
loras/*/archived_*/config.yaml
.git.backup_before_filter/
